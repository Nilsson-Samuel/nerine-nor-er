# Force LF line endings (WSL2 + Linux collaboration)
* text=auto eol=lf

# Source files
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binaries - keep as is
*.png binary
*.jpg binary
*.pkl binary
*.parquet binary
*.npy binary
*.lgb binary
